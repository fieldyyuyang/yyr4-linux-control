# Application specific
# Do not commit local sqlite DBs
*.db
*.sqlite
*.sqlite3
# Do not commit local configs with secrets
local_config.json
secret*.json
.env
.env.local
# Do not commit raw audit data that may contain serial numbers
audit_raw_*.log
